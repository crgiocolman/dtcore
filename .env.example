# Copiar a backend/.env y completar los valores

DATABASE_URL=postgresql+asyncpg://admin:admin123@localhost:5432/dtcore_db
JWT_SECRET=cambiar-por-secreto-seguro-generado
JWT_EXPIRES_HOURS=8
STORAGE_PATH=./storage
BACKUP_DRIVE_REMOTE_PATH=gdrive:dtcore-backups/cliente
SEED_ADMIN_PASSWORD=admin123
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
LOG_FILE_PATH=./logs/backend.log